# ClawForge Agent — Environment Configuration
# Fork of: https://github.com/liufang88789-ui/agent-challenge

# Nosana Configuration
NOSANA_ENDPOINT=https://api.nosana.io
NOSANA_NODE_URL=https://api.mainnet.solana.com

# Wallet: Solana (for Nosana auth)
# Address: 7UqBdYyy9LG59Un6yzjAW8HPcTC4J63B9cZxBHWhhHsg

# LLM: Use Nosana's hosted Qwen3.5-27B or OpenAI fallback
LLM_MODEL=Qwen3.5-27B-AWQ-4bit
